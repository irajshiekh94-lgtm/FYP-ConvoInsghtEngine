# API URL — usually leave UNSET in dev (app auto-detects your Mac's IP from Expo Metro)
#
# Physical phone on any Wi‑Fi: no .env change needed — just run:
#   uvicorn backend.server:app --host 0.0.0.0 --port 8000 --reload
#   cd frontend && npm start
#
# Optional overrides:
# EXPO_PUBLIC_API_URL=http://localhost:8000          # Windows web / local browser
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000            # Android emulator (auto if unset)
# EXPO_PUBLIC_API_URL=https://your-api.onrender.com  # deployed production backend
