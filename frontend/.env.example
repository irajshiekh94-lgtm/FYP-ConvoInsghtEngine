# Windows — same PC (Expo web or testing in browser)
# EXPO_PUBLIC_API_URL=http://localhost:8000

# Android emulator on this PC
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000

# Physical phone on same Wi‑Fi — use your PC's IPv4 from: ipconfig
# (look for "Wireless LAN adapter Wi-Fi" → IPv4 Address, e.g. 192.168.1.10)
EXPO_PUBLIC_API_URL=http://192.168.1.10:8000

# Start backend so other devices can connect:
#   uvicorn backend.server:app --reload --host 0.0.0.0 --port 8000
# If the phone still cannot connect, allow Python through Windows Firewall for port 8000.
