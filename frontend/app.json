{
  "expo": {
    "name": "ConvoInsight",
    "slug": "ConvoInsight",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/ConvoInsightLogo.png",
    "scheme": "convoinsight",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ConvoInsight.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/ConvoInsightLogo.png"
      },
      "package": "com.ConvoInsight.app"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/ConvoInsightLogo.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/ConvoInsightLogo.png",
          "imageWidth": 280,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/ConvoInsightLogo.png",
          "color": "#008069"
        }
      ],
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ]
  }
}
