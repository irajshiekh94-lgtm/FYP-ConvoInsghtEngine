# MongoDB — users, chats, and analysis jobs are stored here
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/convoinsight?retryWrites=true&w=majority

# Meta Llama — local Ollama (Option A)
LLAMA_PROVIDER=ollama
LLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434
PREFER_LOCAL_SUMMARIZER=0
MAX_ML_SUMMARIZE_CLUSTERS=20

# App
SECRET_KEY=your_secret_key_here
DEBUG=False

# Gmail OTP — server sends verification codes TO any user's email
# SMTP_USER is the sender mailbox (your app's mail account), NOT who can log in.
# 1. Enable 2-Step Verification on the Google account
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Paste the 16-character app password below (spaces are OK)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_app_sender@gmail.com
SMTP_PASSWORD=your_16_char_app_password
SMTP_FROM=your_app_sender@gmail.com

# Frontend (Expo) — use your computer's LAN IP so the phone can reach the backend
EXPO_PUBLIC_API_URL=http://YOUR_LAN_IP:8000
